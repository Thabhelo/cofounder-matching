# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/cofounder_matching

# Clerk Authentication
# Get these from your Clerk dashboard: https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_your_secret_key_here
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# CRITICAL: Clerk Frontend API URL for JWT verification
# This should be your Clerk Frontend API domain
# Development: Usually something like https://clerk.your-app.12345.lcl.dev
# Production: Usually something like https://your-domain.clerk.accounts.dev
# Find this in your Clerk dashboard under "API Keys" -> "Frontend API"
CLERK_FRONTEND_API=https://clerk.your-app.lcl.dev

# Clerk Webhook (optional but recommended)
# When a user deletes their account in Clerk, we delete them in our DB so they can re-sign up.
# Create an endpoint in Clerk Dashboard → Webhooks with URL: https://your-api.com/webhooks/clerk
# Subscribe to event: user.deleted. Then paste the "Signing secret" here.
# CLERK_WEBHOOK_SECRET=whsec_xxxx

# Application Configuration
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
PROJECT_NAME=Co-Founder Matching Platform

# CORS Configuration
# Comma-separated list of allowed origins
# Development default includes local dev servers
# For production, add your deployed frontend URLs (e.g., https://your-app.vercel.app)
# NOTE: Wildcard patterns like *.vercel.app are NOT supported
# The JWT "azp" (authorized party) claim must match one of these origins (e.g. http://localhost:3000)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
